<Window x:Class="ElainaUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elaina Executor v0.1"
        Width="900" Height="600"
        MinWidth="700" MinHeight="400"
        Background="{StaticResource BrushBgSecondary}"
        Foreground="{StaticResource BrushTextPrimary}"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="False"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">

    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="{StaticResource BrushBgPrimary}"
                  MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text=" Elaina Executor"
                           Foreground="{StaticResource BrushTextPrimary}"
                           VerticalAlignment="Center" FontSize="12"
                           Margin="8,0" FontWeight="Bold" />

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="MinimizeBtn" Content="&#x2014;" Width="30" Height="24"
                            Background="Transparent"
                            Click="Minimize_Click" />
                    <Button x:Name="CloseBtn" Content="&#x2715;" Width="30" Height="24"
                            Background="Transparent"
                            Click="Close_Click" />
                </StackPanel>
            </Grid>

            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left Panel - Scripts List -->
                <Border Grid.Column="0" Background="{StaticResource BrushBgPrimary}"
                        CornerRadius="4" Margin="0,0,2,0" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Scripts" Margin="8,6"
                                   Foreground="{StaticResource BrushTextSecondary}" FontSize="11" />

                        <ListBox x:Name="ScriptListBox" Grid.Row="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 SelectionChanged="ScriptList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{StaticResource BrushTextPrimary}"
                                               Margin="4,2" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button x:Name="LoadScriptBtn" Grid.Row="2"
                                Content="+ Load Script" Margin="4"
                                Click="LoadScript_Click" />
                    </Grid>
                </Border>

                <!-- Separator -->
                <GridSplitter Grid.Column="1" Width="4"
                              Background="{StaticResource BrushBorder}"
                              ResizeBehavior="PreviousAndNext" />

                <!-- Center & Right - Editor and Console -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="120" />
                    </Grid.RowDefinitions>

                    <!-- Script Editor -->
                    <Border Grid.Row="0" Background="{StaticResource BrushBgPrimary}"
                            CornerRadius="4" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Background="{StaticResource BrushBgTertiary}" Padding="8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Script Editor"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           FontSize="11" VerticalAlignment="Center" />

                                <TextBlock x:Name="StatusText" Grid.Column="1"
                                           Text="Ready"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           FontSize="10" Margin="12,0" VerticalAlignment="Center" />

                                <Button x:Name="ExecuteBtn" Grid.Column="2"
                                        Content="Execute (F6)" Width="100" Height="22"
                                        Click="Execute_Click" Margin="4,0" />

                                <Button x:Name="ClearBtn" Grid.Column="3"
                                        Content="Clear" Width="60" Height="22"
                                        Click="Clear_Click" Margin="4,0"
                                        Background="{StaticResource BrushBgTertiary}" />

                                <Button x:Name="SaveBtn" Grid.Column="4"
                                        Content="Save" Width="60" Height="22"
                                        Click="SaveScript_Click" Margin="4,0"
                                        Background="{StaticResource BrushBgTertiary}" />
                            </Grid>

                            <!-- Code Editor -->
                            <Border Grid.Row="1" Margin="4">
                                <ScrollViewer x:Name="EditorScrollView" Background="#0D1117"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto">
                                    <TextBox x:Name="ScriptEditor"
                                             Background="Transparent"
                                             Foreground="{StaticResource BrushTextPrimary}"
                                             FontFamily="Cascadia Code, Consolas, Courier New"
                                             FontSize="13"
                                             BorderThickness="0"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             TextWrapping="NoWrap"
                                             SpellCheck.IsEnabled="False"
                                             Padding="8"
                                             VerticalAlignment="Stretch"
                                             VerticalContentAlignment="Top"
                                             TextChanged="ScriptEditor_TextChanged"
                                             PreviewKeyDown="ScriptEditor_PreviewKeyDown" />
                                </ScrollViewer>
                            </Border>

                            <!-- Line info bar -->
                            <TextBlock x:Name="LineInfo" Grid.Row="2"
                                       Background="{StaticResource BrushBgTertiary}"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       FontSize="10" Padding="8,2"
                                       Text="Ln: 1 | Col: 1" />
                        </Grid>
                    </Border>

                    <!-- Resizer -->
                    <GridSplitter Grid.Row="1" Height="4"
                                  Background="{StaticResource BrushBorder}"
                                  ResizeBehavior="PreviousAndNext"
                                  HorizontalAlignment="Stretch" />

                    <!-- Console Output -->
                    <Border Grid.Row="2" Background="{StaticResource BrushBgPrimary}"
                            CornerRadius="4" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Background="{StaticResource BrushBgTertiary}" Padding="8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Console"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           FontSize="11" VerticalAlignment="Center" />

                                <Button x:Name="ClearConsoleBtn" Grid.Column="2"
                                        Content="Clear" Width="50" Height="20"
                                        Click="ClearConsole_Click"
                                        Background="{StaticResource BrushBgTertiary}"
                                        FontSize="10" />
                            </Grid>

                            <RichTextBox x:Name="ConsoleOutput"
                                         Grid.Row="1"
                                         Background="#0D1117"
                                         Foreground="{StaticResource BrushTextPrimary}"
                                         FontFamily="Consolas, Courier New"
                                         FontSize="11"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         Margin="4"
                                         VerticalScrollBarVisibility="Auto"
                                         IsDocumentEnabled="True" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="2" Background="{StaticResource BrushBgPrimary}"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                    Padding="8,3">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Ellipse x:Name="StatusIndicator" Grid.Column="0"
                             Width="8" Height="8" Fill="{StaticResource BrushError}"
                             Margin="0,0,6,0" VerticalAlignment="Center" />

                    <TextBlock x:Name="ConnectionStatus" Grid.Column="1"
                               Text="Not connected"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="10" VerticalAlignment="Center" />

                    <TextBlock x:Name="VersionStatus" Grid.Column="2"
                               Text="v0.1.0"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="10" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
