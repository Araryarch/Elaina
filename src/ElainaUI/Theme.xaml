<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme -->
    <Color x:Key="BgPrimary">#1A1A2E</Color>
    <Color x:Key="BgSecondary">#16213E</Color>
    <Color x:Key="BgTertiary">#0F3460</Color>
    <Color x:Key="Accent">#E94560</Color>
    <Color x:Key="AccentHover">#FF6B81</Color>
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#A0A0B0</Color>
    <Color x:Key="Border">#2A2A4A</Color>
    <Color x:Key="Success">#2ECC71</Color>
    <Color x:Key="Error">#E74C3C</Color>

    <SolidColorBrush x:Key="BrushBgPrimary" Color="{StaticResource BgPrimary}" />
    <SolidColorBrush x:Key="BrushBgSecondary" Color="{StaticResource BgSecondary}" />
    <SolidColorBrush x:Key="BrushBgTertiary" Color="{StaticResource BgTertiary}" />
    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="BrushAccentHover" Color="{StaticResource AccentHover}" />
    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource Border}" />
    <SolidColorBrush x:Key="BrushSuccess" Color="{StaticResource Success}" />
    <SolidColorBrush x:Key="BrushError" Color="{StaticResource Error}" />

    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrushAccent}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BrushAccentHover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.8" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BrushBgPrimary}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="CaretBrush" Value="{StaticResource BrushAccent}" />
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource BrushBgPrimary}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
    </Style>
</ResourceDictionary>
