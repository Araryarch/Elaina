<Window x:Class="ElainaUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elaina Executor" Height="720" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0d0d1a" FontFamily="Segoe UI" Foreground="#0d0d1a"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize">
    <Window.Resources>
        <SolidColorBrush x:Key="Dark" Color="#0d0d1a"/>
        <SolidColorBrush x:Key="White" Color="#ffffff"/>
        <SolidColorBrush x:Key="Cyan" Color="#00bcd4"/>
        <SolidColorBrush x:Key="Orange" Color="#ff6d00"/>
        <SolidColorBrush x:Key="Danger" Color="#d50000"/>
        <SolidColorBrush x:Key="Success" Color="#00c853"/>
        <SolidColorBrush x:Key="LightBg" Color="#f5f5f5"/>

        <Style x:Key="BrutalBtn" TargetType="Button">
            <Setter Property="Background" Value="#ffffff"/>
            <Setter Property="Foreground" Value="#0d0d1a"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush" Value="#0d0d1a"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="#0d0d1a" CornerRadius="0"
                                    Margin="3,3,0,0" SnapsToDevicePixels="True"/>
                            <Border Name="bg" Background="{TemplateBinding Background}"
                                    CornerRadius="0" Padding="{TemplateBinding Padding}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#e0f7fa"/>
                                <Setter TargetName="bg" Property="Margin" Value="1,1,0,0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Margin" Value="3,3,0,0"/>
                                <Setter TargetName="bg" Property="Background" Value="#b2ebf2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentBrutalBtn" TargetType="Button" BasedOn="{StaticResource BrutalBtn}">
            <Setter Property="Background" Value="#00bcd4"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#0d0d1a"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#26c6da"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#00acc1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerBrutalBtn" TargetType="Button" BasedOn="{StaticResource BrutalBtn}">
            <Setter Property="Background" Value="#d50000"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#0d0d1a"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e53935"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#c62828"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessBrutalBtn" TargetType="Button" BasedOn="{StaticResource BrutalBtn}">
            <Setter Property="Background" Value="#00c853"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#0d0d1a"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#00e676"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#00a844"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#ffffff" BorderBrush="#0d0d1a" BorderThickness="3" Padding="16,10" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#00bcd4" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,10,0" BorderBrush="#0d0d1a" BorderThickness="2"/>
                    <TextBlock Text="EL AINA" FontSize="20" Foreground="#0d0d1a" FontWeight="ExtraBlack" VerticalAlignment="Center"/>
                    <TextBlock Text=" EXECUTOR" FontSize="13" Foreground="#00bcd4" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#00c853" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0" BorderBrush="#0d0d1a" BorderThickness="2"/>
                    <TextBlock x:Name="StatusText" Text="IDLE" FontSize="12" Foreground="#0d0d1a" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="PidText" Text="" FontSize="12" Foreground="#757575" FontWeight="Bold" Margin="14,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Script Editor -->
            <Border Grid.Column="0" Background="#ffffff" BorderBrush="#0d0d1a" BorderThickness="3" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="52"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Background="#00bcd4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>

                        <TabControl x:Name="ScriptTabs" Grid.Column="0" BorderThickness="0"
                                    Background="Transparent" SelectedIndex="0"
                                    VerticalAlignment="Center" Height="30">
                            <TabControl.Resources>
                                <Style TargetType="TabPanel">
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                </Style>
                                <Style TargetType="TabItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#ccffffff"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Padding" Value="12,6"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TabItem">
                                                <Border Name="border" Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter ContentSource="Header"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#0d0d1a"/>
                                                        <Setter TargetName="border" Property="BorderThickness" Value="0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#00838f"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TabControl.Resources>
                            <TabItem Header="EDITOR"/>
                            <TabItem Header="SCRIPTS"/>
                        </TabControl>

                        <Button x:Name="ClearBtn" Grid.Column="2" Content="X" Width="26" Height="22"
                                FontSize="10" FontWeight="Bold" Style="{StaticResource BrutalBtn}"
                                Padding="0" Click="OnClear" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Editor Panel -->
                    <ScrollViewer Grid.Row="1" x:Name="EditorPanel"
                                  Background="#ffffff" BorderBrush="#0d0d1a" BorderThickness="0,3">
                        <TextBox x:Name="ScriptBox"
                                 AcceptsReturn="True" AcceptsTab="True"
                                 TextWrapping="NoWrap"
                                 Background="#fafafa" Foreground="#0d0d1a"
                                 BorderThickness="0" FontSize="13" FontFamily="Cascadia Code, JetBrains Mono, Consolas"
                                 Padding="14,10" VerticalScrollBarVisibility="Hidden"
                                 SelectionBrush="#00bcd4" SelectionOpacity="0.3"
                                 CaretBrush="#00bcd4"/>
                    </ScrollViewer>

                    <!-- Scripts Panel (tabbed) -->
                    <ScrollViewer Grid.Row="1" x:Name="ScriptsPanel" Visibility="Collapsed"
                                  Background="#fafafa" BorderBrush="#0d0d1a" BorderThickness="0,3"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0">
                            <Border Background="#ffffff" BorderBrush="#e0e0e0" BorderThickness="0,0,0,1" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="DEFAULT SCRIPT" FontSize="11" FontWeight="ExtraBlack" Foreground="#0d0d1a"/>
                                        <TextBlock Text="Basic test script" FontSize="9" Foreground="#9e9e9e"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="LOAD" Style="{StaticResource AccentBrutalBtn}"
                                            Height="26" FontSize="8" Padding="10,0" FontWeight="ExtraBlack"
                                            Tag="print('Hello from Elaina!')" Click="OnLoadScript"/>
                                </Grid>
                            </Border>
                            <Border Background="#ffffff" BorderBrush="#e0e0e0" BorderThickness="0,0,0,1" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="INFINITE YIELD" FontSize="11" FontWeight="ExtraBlack" Foreground="#0d0d1a"/>
                                        <TextBlock Text="Admin commands (placeholder)" FontSize="9" Foreground="#9e9e9e"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="LOAD" Style="{StaticResource AccentBrutalBtn}"
                                            Height="26" FontSize="8" Padding="10,0" FontWeight="ExtraBlack"
                                            Tag="-- Infinite Yield placeholder" Click="OnLoadScript"/>
                                </Grid>
                            </Border>
                            <Border Background="#ffffff" BorderBrush="#e0e0e0" BorderThickness="0,0,0,1" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="ESP / WALLHACK" FontSize="11" FontWeight="ExtraBlack" Foreground="#0d0d1a"/>
                                        <TextBlock Text="Player ESP visual (placeholder)" FontSize="9" Foreground="#9e9e9e"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="LOAD" Style="{StaticResource AccentBrutalBtn}"
                                            Height="26" FontSize="8" Padding="10,0" FontWeight="ExtraBlack"
                                            Tag="-- ESP placeholder" Click="OnLoadScript"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="#0d0d1a" Padding="10,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="CTRL + ENTER" FontSize="11" Foreground="#616161" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button x:Name="ExecuteBtn" Grid.Column="1"
                                    Content="EXECUTE" Style="{StaticResource AccentBrutalBtn}"
                                    Height="32" FontSize="11" Padding="24,0" FontWeight="ExtraBlack"
                                    Click="OnExecute" IsEnabled="False"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Console Panel -->
            <Border Grid.Column="1" Background="#ffffff" BorderBrush="#0d0d1a" BorderThickness="3">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Background="#0d0d1a">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="CONSOLE" FontSize="12" FontWeight="ExtraBlack" Foreground="#ffffff" VerticalAlignment="Center" Margin="14,0,0,0"/>
                        <Button x:Name="ClearConsoleBtn" Grid.Column="1" Content="X" Width="30" Height="24" FontSize="10" FontWeight="Bold" Style="{StaticResource BrutalBtn}" Padding="0" Click="OnClearConsole" Margin="0,0,10,0"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" Background="#ffffff" BorderBrush="#0d0d1a" BorderThickness="0,3" VerticalScrollBarVisibility="Auto">
                        <RichTextBox x:Name="ConsoleBox" IsReadOnly="True"
                                     Background="#fafafa" BorderThickness="0"
                                     FontSize="11.5" FontFamily="Cascadia Code, JetBrains Mono, Consolas"
                                     Padding="12,8" VerticalScrollBarVisibility="Disabled">
                            <FlowDocument>
                                <Paragraph Margin="0" Padding="0">
                                    <Run Text="[EL AINA] v1.0.0 ready" Foreground="#00bcd4" FontWeight="Bold"/>
                                </Paragraph>
                            </FlowDocument>
                        </RichTextBox>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="10,10,10,12">
                        <Button x:Name="AttachBtn" Content="ATTACH" Style="{StaticResource AccentBrutalBtn}" Height="34" FontSize="11" FontWeight="ExtraBlack" Click="OnAttach" Margin="0,0,0,8"/>
                        <Button x:Name="InjectBtn" Content="INJECT UNC" Style="{StaticResource BrutalBtn}" Height="32" FontSize="11" FontWeight="Bold" Click="OnInject" IsEnabled="False" Margin="0,0,0,8"/>
                        <Button x:Name="DetachBtn" Content="DETACH" Style="{StaticResource DangerBrutalBtn}" Height="32" FontSize="11" FontWeight="Bold" Click="OnDetach"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#ffffff" BorderBrush="#0d0d1a" BorderThickness="3" Padding="14,6" Margin="0,14,0,0" Height="36">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="READY" FontSize="11" Foreground="#757575" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="X64  |  EL AINA V1.0" FontSize="10" Foreground="#00bcd4" FontWeight="Bold" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
