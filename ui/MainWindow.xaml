<Window x:Class="ElainaUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elaina" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e" FontFamily="Consolas" Foreground="#e0e0e0">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Elaina" FontSize="28" Foreground="#e94560"
                   HorizontalAlignment="Center" Grid.Row="0" Margin="0,0,0,10"/>

        <!-- Status bar -->
        <Border Grid.Row="1" Background="#16213e" Padding="8" CornerRadius="4" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Status: " FontWeight="Bold"/>
                <TextBlock x:Name="StatusText" Text="Idle" Foreground="#888"/>
                <Button x:Name="AttachBtn" Content="Attach" Width="80" Height="24"
                        Margin="20,0,0,0" Click="OnAttach" Background="#0f3460" BorderThickness="0"/>
                <Button x:Name="InjectBtn" Content="Inject" Width="80" Height="24"
                        Margin="8,0,0,0" Click="OnInject" Background="#0f3460" BorderThickness="0"
                        IsEnabled="False"/>
                <Button x:Name="DetachBtn" Content="Detach" Width="80" Height="24"
                        Margin="8,0,0,0" Click="OnDetach" Background="#0f3460" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- Script editor -->
        <Border Grid.Row="2" Background="#16213e" CornerRadius="4" Padding="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Script Editor" Foreground="#888" Margin="4,0,0,4"/>
                <TextBox x:Name="ScriptBox" Grid.Row="1"
                         AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto"
                         Background="#0f3460" Foreground="#e0e0e0"
                         BorderThickness="0" FontSize="13"
                         Padding="4"/>
            </Grid>
        </Border>

        <!-- Execute button -->
        <Button x:Name="ExecuteBtn" Grid.Row="3" Content="Execute (Ctrl+Enter)"
                Height="36" Margin="0,8,0,0"
                Click="OnExecute" Background="#e94560" Foreground="White"
                BorderThickness="0" FontSize="14" FontWeight="Bold"
                IsEnabled="False"/>
    </Grid>
</Window>
